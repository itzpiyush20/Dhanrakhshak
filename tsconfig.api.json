{
  "compilerOptions": {
    "target": "es2020",
    "module": "node16",
    "lib": ["ES2020"],
    "types": ["node"],
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": ".vercel/output/functions",
    "rootDir": ".",
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.api.tsbuildinfo"
  },
  "include": ["api/**/*.ts"]
}
